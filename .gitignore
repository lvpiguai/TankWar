# 忽略 VS Code 的设置文件夹
.vscode/

# 忽略 IntelliJ IDEA 项目的配置文件（如果有的话）
.idea/

# 忽略操作系统自动生成的文件
.DS_Store
Thumbs.db

# 忽略编译生成的 Java 类文件
*.class

# 忽略 Maven 的目标文件夹（如果你使用 Maven）
target/

# 忽略日志文件
*.log

# 忽略 Java 的构建输出目录（如 Gradle 构建工具的输出）
build/

# 忽略 jar 包文件（如果不需要提交打包后的文件）
*.jar

# 忽略 .env 文件（如果你使用环境变量）
.env

# 忽略用户自定义的临时文件
*.swp
*.swo
